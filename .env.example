APP_NAME=PitStop
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://demo.iaqueatende.com.br
# Token para rota /sys/migrate/{token} — remover após uso
MIGRATE_TOKEN=

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Banco de dados (PostgreSQL — preenchido pelo Coolify) ──────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pitstop
DB_USERNAME=pitstop
DB_PASSWORD=

# ── Sessão ────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.iaqueatende.com.br
# OBRIGATÓRIO em produção HTTPS: garante cookie apenas via HTTPS e bloqueia CSRF cross-site
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ── Cache ─────────────────────────────────────────────────────
CACHE_STORE=database

# ── Queue ─────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── Sanctum (wildcard para todos os subdomínios) ──────────────
SANCTUM_STATEFUL_DOMAINS=demo.iaqueatende.com.br,*.iaqueatende.com.br

# Token expira em 8 horas (em minutos). 0 = nunca.
SANCTUM_TOKEN_EXPIRATION=480

# Tenant padrão — usado como fallback, não em produção
DEFAULT_TENANT_SLUG=demo

# ── Mail ──────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@iaqueatende.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ── Filesystem ────────────────────────────────────────────────
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ── Perfis de acesso ──────────────────────────────────────────
# admin    → acesso total
# gerente  → acesso operacional (sem gestão de usuários)
# operador → apenas fila e agendamentos

# ── Usuário admin inicial (seeder) ────────────────────────────
ADMIN_EMAIL=admin@iaqueatende.com.br
ADMIN_PASSWORD=Mudar@123

# == Asaas (gateway de pagamento) ==
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=
ASAAS_PAYMENT_LINK_URL=
ASAAS_PAYMENT_LINK_URL_PRO=
ASAAS_PAYMENT_LINK_URL_PRO_MAX=
