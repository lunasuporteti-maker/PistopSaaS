APP_NAME=PitStop
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-dominio.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Banco de dados (PostgreSQL) ───────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pitstop
DB_USERNAME=pitstop
DB_PASSWORD=senha_segura_aqui

# ── Sessão ────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=seu-dominio.com.br

# ── Cache ─────────────────────────────────────────────────────
CACHE_STORE=database

# ── Queue ─────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── Sanctum ───────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=seu-dominio.com.br

# Token expira em 8 horas (em minutos). 0 = nunca.
SANCTUM_TOKEN_EXPIRATION=480

# ── Mail ──────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.exemplo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@seu-dominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ── Filesystem ────────────────────────────────────────────────
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ── Perfis de acesso ──────────────────────────────────────────
# admin    → acesso total
# gerente  → acesso operacional (sem gestão de usuários)
# operador → apenas fila e agendamentos

# ── Usuário admin inicial (usado pelo seeder) ─────────────────
ADMIN_EMAIL=admin@seu-dominio.com.br
ADMIN_PASSWORD=Mudar@123
